# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Python files
[*.py]
indent_style = space
indent_size = 4
charset = utf-8

# TypeScript and JavaScript files
[*.{js,jsx,ts,tsx}]
indent_style = space
indent_size = 2
charset = utf-8

# JSON, YAML, TOML files
[*.{json,yaml,yml,toml}]
indent_style = space
indent_size = 2
charset = utf-8

# Markdown files
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# Configuration files
[*.{cfg,ini}]
indent_style = space
indent_size = 4

# Git files
[.gitignore]
indent_style = space
indent_size = 4
insert_final_newline = false
